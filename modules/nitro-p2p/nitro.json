{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["nitrop2p"],
  "ios": {
    "iosModuleName": "NitroP2p"
  },
  "android": {
    "androidNamespace": ["nitrop2p"],
    "androidCxxLibName": "NitroP2p"
  },
  "autolinking": {
        "P2p": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridP2p"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridP2p"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
